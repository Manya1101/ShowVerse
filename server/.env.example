# Server environment variables (set these in Render Dashboard -> Environment)

# Include the database name before the query string.
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@CLUSTER.mongodb.net/ShowVerse?retryWrites=true&w=majority
CLERK_SECRET_KEY=
TMDB_API_KEY=

# Comma-separated list. Leave empty to allow all origins.
CORS_ORIGINS=https://your-frontend-domain.com,http://localhost:5173

# Optional (feature-specific):
# CLERK_PUBLISHABLE_KEY=
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# CLOUDINARY_...=
# SMTP_USER=
# SMTP_PASS=
# SENDER_EMAIL=

PORT=3000
